{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rubyn JSON-RPC 2.0 Protocol",
  "description": "Protocol definition for communication between the RubyMine plugin and the rubyn-code agent process over stdio.",
  "version": "1.1.0",
  "transport": {
    "type": "stdio",
    "framing": "newline-delimited JSON (NDJSON)",
    "encoding": "UTF-8"
  },
  "requests": {
    "initialize": {
      "direction": "plugin → agent",
      "description": "Sent once after the process starts. Must be the first request.",
      "params": {
        "workspacePath": "string — absolute path to the open project",
        "extensionVersion": "string — semver of the plugin (e.g. '0.1.0')",
        "capabilities": "object? — optional client capability flags"
      },
      "result": {
        "serverVersion": "string — semver of rubyn-code",
        "protocolVersion": "string — protocol version",
        "workspacePath": "string — confirmed workspace path",
        "capabilities": {
          "streaming": "boolean",
          "tools": "integer — number of tools available",
          "skills": "integer — number of skills available",
          "review": "boolean",
          "memory": "boolean",
          "teams": "boolean",
          "toolApproval": "boolean",
          "editApproval": "boolean"
        }
      }
    },
    "shutdown": {
      "direction": "plugin → agent",
      "description": "Graceful shutdown request. Agent should flush and exit.",
      "params": null,
      "result": null
    },
    "session/resume": {
      "direction": "plugin → agent",
      "description": "Resumes an existing chat session by ID.",
      "params": {
        "sessionId": "string — session UUID to resume"
      },
      "result": null
    },
    "session/reset": {
      "direction": "plugin → agent",
      "description": "Resets a session, clearing its conversation history.",
      "params": {
        "sessionId": "string — session UUID to reset"
      },
      "result": null
    },
    "session/list": {
      "direction": "plugin → agent",
      "description": "Lists all available sessions.",
      "params": null,
      "result": {
        "sessions": [
          {
            "id": "string — session UUID",
            "title": "string — session title",
            "updatedAt": "string (ISO-8601)",
            "messageCount": "integer"
          }
        ]
      }
    },
    "session/fork": {
      "direction": "plugin → agent",
      "description": "Forks an existing session into a new branch.",
      "params": {
        "sessionId": "string — session to fork from"
      },
      "result": null
    },
    "prompt": {
      "direction": "plugin → agent",
      "description": "Sends a user prompt. The agent streams the response via stream/text notifications.",
      "params": {
        "text": "string — user message text",
        "sessionId": "string? — target session (optional, uses current)",
        "context": {
          "workspacePath": "string? — workspace root path",
          "activeFile": "string? — currently active file path",
          "selection": {
            "startLine": "integer",
            "endLine": "integer",
            "text": "string — selected text"
          },
          "openFiles": "string[]? — list of open file paths"
        }
      },
      "result": null
    },
    "cancel": {
      "direction": "plugin → agent",
      "description": "Cancels an in-progress prompt. Agent stops streaming.",
      "params": {
        "sessionId": "string"
      },
      "result": null
    },
    "review": {
      "direction": "plugin → agent",
      "description": "Requests a code review.",
      "params": {
        "sessionId": "string? — optional session context",
        "baseBranch": "string? — base branch for diff comparison",
        "focus": "string? — review focus hint (e.g. 'performance', 'security')"
      },
      "result": null
    },
    "approveToolUse": {
      "direction": "plugin → agent",
      "description": "Approves or denies a pending tool call from the agent.",
      "params": {
        "requestId": "string — ID of the tool use request",
        "approved": "boolean — true to approve, false to deny"
      },
      "result": null
    },
    "acceptEdit": {
      "direction": "plugin → agent",
      "description": "Accepts or rejects a proposed file edit.",
      "params": {
        "editId": "string — ID of the edit proposal",
        "accepted": "boolean — true to accept, false to reject"
      },
      "result": null
    },
    "config/get": {
      "direction": "plugin → agent",
      "description": "Gets configuration values.",
      "params": null,
      "result": "object — configuration key-value pairs"
    },
    "config/set": {
      "direction": "plugin → agent",
      "description": "Sets configuration values.",
      "params": "object — configuration key-value pairs to set",
      "result": null
    },
    "models/list": {
      "direction": "plugin → agent",
      "description": "Lists available AI models.",
      "params": null,
      "result": "object — list of available models"
    }
  },
  "notifications": {
    "stream/text": {
      "direction": "agent → plugin",
      "description": "A streaming text chunk from the agent. When 'final' is true, streaming is complete and 'text' contains the full assembled content.",
      "params": {
        "sessionId": "string",
        "text": "string — text chunk (or full content when final=true)",
        "final": "boolean — true when this is the last chunk (default: false)"
      }
    },
    "tool/use": {
      "direction": "agent → plugin",
      "description": "Agent wants to call a tool, optionally awaiting approval.",
      "params": {
        "requestId": "string — unique ID for this tool call",
        "tool": "string — tool name",
        "args": "object — tool arguments",
        "requiresApproval": "boolean — whether the plugin must approve before execution (default: false)"
      }
    },
    "tool/result": {
      "direction": "agent → plugin",
      "description": "Result of a tool execution.",
      "params": {
        "requestId": "string — matches the tool/use requestId",
        "tool": "string — tool name",
        "success": "boolean — whether the tool succeeded",
        "summary": "string — human-readable summary of the result"
      }
    },
    "file/edit": {
      "direction": "agent → plugin",
      "description": "Agent proposes a file edit.",
      "params": {
        "editId": "string — unique ID for this edit",
        "path": "string — file path",
        "content": "string — proposed file content",
        "type": "string? — edit type (e.g. 'update', 'create')"
      }
    },
    "file/create": {
      "direction": "agent → plugin",
      "description": "Agent proposes creating a new file.",
      "params": {
        "editId": "string — unique ID for this creation",
        "path": "string — file path",
        "content": "string — file content"
      }
    },
    "agent/status": {
      "direction": "agent → plugin",
      "description": "Agent lifecycle status update.",
      "params": {
        "sessionId": "string",
        "status": "string — 'thinking' | 'streaming' | 'done' | 'cancelled' | 'error' | 'reviewing'",
        "error": "string? — error message when status is 'error'",
        "summary": "string? — summary when status is 'done'"
      }
    },
    "session/cost": {
      "direction": "agent → plugin",
      "description": "Cumulative token usage and cost for a session.",
      "params": {
        "sessionId": "string",
        "inputTokens": "integer",
        "outputTokens": "integer",
        "costUsd": "number"
      }
    },
    "agent/error": {
      "direction": "agent → plugin",
      "description": "Unrecoverable error from the agent not tied to a specific request.",
      "params": {
        "message": "string",
        "code": "integer?",
        "sessionId": "string?"
      }
    },
    "review/finding": {
      "direction": "agent → plugin",
      "description": "A code review finding from the agent.",
      "params": {
        "sessionId": "string",
        "index": "integer — finding number",
        "severity": "string — severity level",
        "message": "string — finding description",
        "file": "string? — file path",
        "line": "integer? — line number"
      }
    },
    "config/changed": {
      "direction": "agent → plugin",
      "description": "Notification that configuration has changed.",
      "params": "object — changed configuration values"
    }
  },
  "error_codes": {
    "-32700": "Parse error — invalid JSON",
    "-32600": "Invalid request",
    "-32601": "Method not found",
    "-32602": "Invalid params",
    "-32603": "Internal error",
    "1001": "Not initialized",
    "1002": "Session not found",
    "1003": "Prompt already in progress",
    "1004": "Authentication error"
  }
}
