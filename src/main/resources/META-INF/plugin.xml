<idea-plugin>
    <id>com.rubyn.rubymine</id>
    <name>Rubyn</name>
    <vendor email="support@rubyn.dev" url="https://rubyn.dev">Rubyn</vendor>

    <description><![CDATA[
        <b>Rubyn</b> — AI pair programmer for Ruby and Rails projects.<br><br>
        Rubyn connects your IDE to a local rubyn-code agent that understands your entire
        codebase. Ask questions, request edits, and review proposed diffs without leaving
        RubyMine or IntelliJ IDEA Ultimate.
    ]]></description>

    <change-notes><![CDATA[
        <b>0.1.0</b> — Initial release.
    ]]></change-notes>

    <!-- Platform and Ruby plugin dependency -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.ruby</depends>

    <resource-bundle>messages.RubynBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ── Tool Window ──────────────────────────────────────────────── -->
        <toolWindow
            id="Rubyn"
            anchor="right"
            secondary="false"
            icon="com.rubyn.icons.RubynIcons.ToolWindowIcon"
            factoryClass="com.rubyn.toolwindow.RubynToolWindowFactory"
            conditionClass="com.rubyn.toolwindow.RubynToolWindowCondition"/>

        <!-- ── Application-level services ──────────────────────────────── -->
        <applicationService
            serviceInterface="com.rubyn.settings.RubynSettingsService"
            serviceImplementation="com.rubyn.settings.RubynSettingsService"/>

        <!-- ── Project-level services ───────────────────────────────────── -->
        <projectService
            serviceInterface="com.rubyn.services.RubynProjectService"
            serviceImplementation="com.rubyn.services.RubynProjectService"/>

        <projectService
            serviceInterface="com.rubyn.services.RubynProcessService"
            serviceImplementation="com.rubyn.services.RubynProcessService"/>

        <projectService
            serviceInterface="com.rubyn.context.ContextProvider"
            serviceImplementation="com.rubyn.context.ContextProvider"/>

        <projectService
            serviceInterface="com.rubyn.context.ProjectDetector"
            serviceImplementation="com.rubyn.context.ProjectDetector"/>

        <!-- ── Diff Manager (Task 8) ─────────────────────────────────────── -->
        <projectService
            serviceInterface="com.rubyn.diff.RubynDiffManager"
            serviceImplementation="com.rubyn.diff.RubynDiffManager"/>

        <!-- ── Settings / Configurable ──────────────────────────────────── -->
        <applicationConfigurable
            parentId="tools"
            instance="com.rubyn.settings.RubynConfigurable"
            id="com.rubyn.settings.RubynConfigurable"
            displayName="Rubyn"/>

        <!-- ── Status Bar Widget ────────────────────────────────────────── -->
        <statusBarWidgetFactory
            id="com.rubyn.statusbar.RubynStatusBarWidget"
            implementation="com.rubyn.statusbar.RubynStatusBarWidgetFactory"
            order="after Position"/>

        <!-- ── Notification Group ───────────────────────────────────────── -->
        <notificationGroup
            id="Rubyn"
            displayType="BALLOON"
            key="notification.group.rubyn"/>

        <!-- ── Startup Activity ─────────────────────────────────────────── -->
        <postStartupActivity
            implementation="com.rubyn.startup.RubynStartupActivity"/>

    </extensions>

    <actions>

        <!-- ── Main Menu: Tools > Rubyn ─────────────────────────────────── -->
        <group
            id="com.rubyn.actions.MainMenu"
            text="Rubyn"
            description="Rubyn AI pair programmer actions"
            popup="true">

            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <!-- Open Chat — Cmd+Shift+R / Ctrl+Shift+R -->
            <action
                id="com.rubyn.actions.OpenChat"
                class="com.rubyn.actions.OpenChatAction"
                text="Open Chat"
                description="Open Rubyn chat panel"
                icon="com.rubyn.icons.RubynIcons.ActionIcon">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift R"/>
            </action>

            <separator/>

            <!-- Explain Selection — Cmd+Shift+E / Ctrl+Shift+E -->
            <action
                id="com.rubyn.actions.ExplainCode"
                class="com.rubyn.actions.ExplainCodeAction"
                text="Explain Selection"
                description="Ask Rubyn to explain the selected code or current file">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift E"/>
            </action>

            <!-- Refactor with Rubyn — Cmd+Shift+F / Ctrl+Shift+F -->
            <action
                id="com.rubyn.actions.RefactorCode"
                class="com.rubyn.actions.RefactorCodeAction"
                text="Refactor with Rubyn"
                description="Ask Rubyn to refactor the selected code">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift F"/>
            </action>

            <!-- Review Selection -->
            <action
                id="com.rubyn.actions.ReviewCode"
                class="com.rubyn.actions.ReviewCodeAction"
                text="Review with Rubyn"
                description="Ask Rubyn to review the selected code"/>

            <!-- Generate Specs -->
            <action
                id="com.rubyn.actions.GenerateSpecs"
                class="com.rubyn.actions.GenerateSpecsAction"
                text="Generate Specs"
                description="Ask Rubyn to generate RSpec specs for the current Ruby file"/>

            <separator/>

            <!-- Review PR -->
            <action
                id="com.rubyn.actions.ReviewPR"
                class="com.rubyn.actions.ReviewPRAction"
                text="Review Pull Request…"
                description="Ask Rubyn to review a pull request by branch name"/>

            <!-- Select Model -->
            <action
                id="com.rubyn.actions.SelectModel"
                class="com.rubyn.actions.SelectModelAction"
                text="Select Model…"
                description="Choose the AI model used for Rubyn prompts"/>

        </group>

        <!-- ── Editor Context Menu: Rubyn ───────────────────────────────── -->
        <group
            id="com.rubyn.actions.EditorContext"
            text="Rubyn"
            description="Rubyn AI actions"
            popup="true">

            <add-to-group group-id="EditorPopupMenu" anchor="last"/>

            <reference ref="com.rubyn.actions.ExplainCode"/>
            <reference ref="com.rubyn.actions.RefactorCode"/>
            <reference ref="com.rubyn.actions.ReviewCode"/>
            <reference ref="com.rubyn.actions.GenerateSpecs"/>
            <reference ref="com.rubyn.actions.OpenChat"/>

        </group>

        <!-- ── Diff Viewer Toolbar: Accept / Reject (Task 8) ───────────────── -->
        <group id="com.rubyn.diff.DiffToolbar">
            <add-to-group group-id="Diff.ViewerToolbar" anchor="first"/>

            <action
                id="com.rubyn.diff.AcceptEdit"
                class="com.rubyn.diff.AcceptEditAction"
                text="Accept Edit"
                description="Accept this proposed file change and write it to disk"
                icon="com.rubyn.icons.RubynIcons.AcceptEdit"/>

            <action
                id="com.rubyn.diff.RejectEdit"
                class="com.rubyn.diff.RejectEditAction"
                text="Reject Edit"
                description="Reject this proposed file change"
                icon="com.rubyn.icons.RubynIcons.RejectEdit"/>
        </group>

    </actions>

</idea-plugin>
